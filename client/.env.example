VITE_API_URL=http://localhost:5000/api
# WhatsApp business number in international format (e.g. +21612345678). Leave blank to hide the button.
VITE_WHATSAPP_NUMBER=+21694243333
VITE_SENTRY_DSN=
# Cal.com booking embed — find your link at cal.com/settings/profile
# Set to your Cal.com username or username/event-slug (e.g. "secritou" or "secritou/discovery-call")
# If unset, the contact page falls back to a static "book a call" card with a
# mailto: link instead of the live calendar widget — see ContactPage.tsx
# (CalBookingSection). A production build without this set will warn at build
# time (see vite.config.ts) but will not fail the build.
VITE_CALCOM_LINK=your-calcom-username
# Google Analytics 4 measurement ID — find it in GA Admin > Data Streams > Web
# Leave as the placeholder to disable analytics; tracking only fires on public landing pages.
VITE_GA4_ID=G-XXXXXXXXXX
# Public site origin used for canonical URLs, sitemap and Open Graph tags
VITE_SITE_URL=https://secritou.tn
