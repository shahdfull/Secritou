NODE_ENV=development
PORT=5000
# Fuseau horaire métier : les bornes MTD/YTD des KPI (executiveMetrics, dashboard)
# utilisent l'heure locale du process Node. Sans ce réglage, un serveur en UTC
# décale d'une heure les fins de mois par rapport à l'heure tunisienne.
TZ=Africa/Tunis
# Seed : SEED_DEMO=false pour un seed de production minimal (admin + services +
# profils de permissions + contenu CMS, sans clients/projets/factures de démo)
SEED_DEMO=true
# Logger verbosity: debug | info | warn | error
LOG_LEVEL=info
DATABASE_URL=postgresql://user:password@localhost:5432/secritou_db
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# URL du frontend (sans slash final)
FRONTEND_URL=http://localhost:5173
# URL publique de cette API — utilisée pour construire des callbacks vers des services
# externes (n8n). Si n8n tourne en Docker et l'API sur l'hôte, utiliser
# host.docker.internal au lieu de localhost.
API_URL=http://localhost:5000
REDIS_URL=redis://localhost:6379
# Active le cache Redis déjà implémenté : mettre à true en production pour réduire la charge DB
CACHE_ENABLED=true
# File storage (S3-compatible: AWS S3, MinIO, R2, Backblaze).
# Local dev (docker-compose MinIO, see ./scripts/init-minio.sh):
#   S3_ENDPOINT=http://localhost:9000
#   S3_BUCKET=secritou-dev
#   S3_ACCESS_KEY_ID=minioadmin
#   S3_SECRET_ACCESS_KEY=minioadmin
#   S3_REGION=us-east-1
#   S3_PUBLIC_URL=http://localhost:9000/secritou-dev
# Production self-hosted MinIO:
#   S3_ENDPOINT=https://<your-minio-host>       (e.g. https://minio.secritou.com)
#   S3_BUCKET=secritou-prod
#   S3_ACCESS_KEY_ID=<minio-access-key>
#   S3_SECRET_ACCESS_KEY=<minio-secret-key>
#   S3_REGION=us-east-1                          (MinIO ignores the value but the SDK requires one)
#   S3_PUBLIC_URL=https://<public-url-or-cdn-in-front-of-minio>
# Real AWS S3: leave S3_ENDPOINT unset, set S3_REGION to the bucket's actual region.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_PUBLIC_URL=
# Set true only if the bucket/objects are public-read (skips signed URLs)
S3_PUBLIC_ACL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# 32-byte key (hex or base64) used to AES-256-GCM encrypt OAuth refresh tokens at rest.
# Required when GOOGLE_OAUTH_CLIENT_ID/SECRET/REDIRECT_URI are configured.
INTEGRATIONS_ENCRYPTION_KEY=
# Company that owns leads generated by the public website contact form.
INTERNAL_COMPANY_ID=seed-company-001
SENTRY_DSN=
ADMIN_NOTIFICATION_EMAIL=contact@secritou.tn
# Revenue forecast recalibration — adjust once there's real conversion data instead
# of editing code. Win-probability (0-1) per proposal status, and days overdue before
# a client is flagged "at risk" on the executive dashboard.
FORECAST_PROBABILITY_SENT=0.2
FORECAST_PROBABILITY_VIEWED=0.4
FORECAST_AT_RISK_DAYS=30
# Détection d'anomalie GSC : signale un client quand ses clics du dernier jour synchronisé
# dévient de la moyenne des 7 jours précédents d'au moins ce pourcentage (0-1).
GSC_ANOMALY_THRESHOLD_PCT=0.5
# Seuils SLA pour les alertes n8n (voir docs/n8n-events.md) : une question client sans
# réponse staff, ou une approbation en attente, au-delà de ces durées déclenche
# customQuestion.sla_breach / approval.sla_breach.
CUSTOM_QUESTION_SLA_HOURS=24
APPROVAL_SLA_DAYS=3
# n8n integration (optional): outbound event webhooks (Slack/Teams notifications,
# LLM-enriched reports, etc). Leave both unset to disable — must be set together.
# Local dev (docker-compose n8n, see docker-compose.yml): base URL is n8n's webhook
# prefix, e.g. http://localhost:5678/webhook — each event posts to "<base>/<event>".
# N8N_WEBHOOK_SECRET must match the value your n8n workflows use to verify
# X-Secritou-Signature (HMAC-SHA256 of the raw JSON body).
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=
