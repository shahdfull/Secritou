NODE_ENV=development
PORT=5000
# Fuseau horaire métier : les bornes MTD/YTD des KPI (executiveMetrics, dashboard)
# utilisent l'heure locale du process Node. Sans ce réglage, un serveur en UTC
# décale d'une heure les fins de mois par rapport à l'heure tunisienne.
TZ=Africa/Tunis
# Seed : SEED_DEMO=false pour un seed de production minimal (admin + services +
# profils de permissions + contenu CMS, sans clients/projets/factures de démo)
SEED_DEMO=true
# Logger verbosity: debug | info | warn | error
LOG_LEVEL=info
DATABASE_URL=postgresql://user:password@localhost:5432/secritou_db
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# URL du frontend (sans slash final)
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379
# Active le cache Redis déjà implémenté : mettre à true en production pour réduire la charge DB
CACHE_ENABLED=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Company that owns leads generated by the public website contact form.
INTERNAL_COMPANY_ID=seed-company-001
SENTRY_DSN=
