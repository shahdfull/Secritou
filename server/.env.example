NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secritou?schema=public
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_ISSUER=secritou-api
JWT_AUDIENCE=secritou-web
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=secritou_refresh
CLIENT_ORIGIN=http://localhost:5173
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
CONTACT_RECEIVER_EMAIL=hello@secritou.com
OPENAI_API_KEY=
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=change-me-metrics-token
REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=6379
CACHE_ENABLED=true
JOBS_ENABLED=true
