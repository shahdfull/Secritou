generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role definitions
enum Role {
  ADMIN
  MANAGER
  CLIENT
  FREELANCER
}

// Status of a custom question asked from the FAQ
enum CustomQuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

// Project status options
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

// Task status options
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// Lead status options for sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

// Contact request status options
enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

// Mission status options for freelancer marketplace
enum MissionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Mission Application status
enum MissionApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Freelancer Application status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Client Onboarding Step Status
enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// Contract Status
enum ContractStatus {
  PENDING
  SIGNED
}

// Payment Status
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Specification Approval Status
enum SpecApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Service request status options
enum ServiceRequestStatus {
  NEW
  IN_REVIEW
  IN_PROGRESS
  WAITING_CLIENT
  COMPLETED
  CANCELLED
  // Legacy values kept for migration compatibility
  DONE
}

// Document type options
enum DocumentType {
  INVOICE
  CONTRACT
  OTHER
}

// Multi-tenant Company model
model Company {
  id                  String                @id @default(uuid())
  name                String                @db.VarChar(255)
  website             String?               @db.VarChar(255)
  logoUrl             String?               @db.VarChar(255)
  primaryColor        String?               @db.VarChar(20)
  users               User[]
  leads               Lead[]
  clients             Client[]
  projects            Project[]
  missions            FreelancerMission[]
  serviceRequests     ServiceRequest[]
  documents           Document[]
  proposals           Proposal[]
  approvals           Approval[]
  enhancedDocuments   EnhancedDocument[]
  invoices            Invoice[]
  creditNotes         CreditNote[]
  clientSuccess       ClientSuccess[]
  clientOnboardings        ClientOnboarding[]
  freelancerApplications   FreelancerApplication[]
  aiConversations      AiConversation[]
  customQuestions      CustomQuestion[]
  createdAt           DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([name])
}

// User model for all platform users
model User {
  id                  String               @id @default(uuid())
  email               String               @db.VarChar(255)
  name                String               @db.VarChar(255)
  passwordHash        String               @db.VarChar(255)
  role                Role                 @default(CLIENT)
  mustChangePassword  Boolean              @default(false)
  companyId           String?
  company             Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  clientId            String?
  client              Client?              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks               Task[]               @relation("AssignedTasks")
  comments            Comment[]
  refreshTokens       RefreshToken[]
  freelancerProfile FreelancerProfile?
  notifications Notification[]
  resetToken String? @db.VarChar(255)
  resetTokenExpiry DateTime? @db.Timestamptz(6)
  freelancerApplications FreelancerApplication[]
  clientOnboardingsAsAssignee ClientOnboarding[] @relation("ClientOnboardingAssignedUser")
  proposalHistories    ProposalHistory[]
  approvalTimelines    ApprovalTimeline[]
  documentAccessLogs   DocumentAccessLog[]
  assignedServiceRequests ServiceRequestComment[] @relation("ServiceRequestCommentAuthor")
  serviceRequestHistory   ServiceRequestHistory[] @relation("ServiceRequestHistoryUser")
  serviceRequestAssignments ServiceRequest[]      @relation("ServiceRequestAssignee")
  givenRatings        FreelancerRating[]
  recordedInvoicePayments InvoicePayment[]  @relation("RecordedInvoicePayments")
  aiConversations     AiConversation[]
  customQuestions        CustomQuestion[]
  customQuestionMessages CustomQuestionMessage[]
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(6)

  @@unique([companyId, email])

  // Indexes for faster queries
  @@index([companyId])
  @@index([clientId])
  @@index([email])
  @@index([companyId, role])
  @@index([resetToken])
  @@index([companyId, createdAt])
}

// Lead model for potential clients/sales pipeline
model Lead {
  id                String     @id @default(uuid())
  name              String     @db.VarChar(255)
  email             String?    @db.VarChar(255)
  phone             String?    @db.VarChar(50)
  source            String?    @db.VarChar(100)
  status            LeadStatus @default(NEW)
  notes             String?    @db.Text
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  convertedClientId String?
  archivedAt        DateTime?  @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)

  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([email])
  @@index([archivedAt])
}

// Client model for paying/active clients
model Client {
  id               String           @id @default(uuid())
  name             String           @db.VarChar(255)
  email            String?          @db.VarChar(255)
  phone            String?          @db.VarChar(50)
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects         Project[]
  users            User[]
  serviceRequests  ServiceRequest[]
  documents        Document[]
  proposals        Proposal[]
  approvals        Approval[]
  enhancedDocuments EnhancedDocument[]
  invoices         Invoice[]
  creditNotes      CreditNote[]
  creditBalance    Decimal          @default(0) @db.Decimal(12, 2)
  clientSuccess    ClientSuccess?
  clientOnboardings ClientOnboarding[]
  archivedAt       DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([email])
  @@index([archivedAt])
}
model ServiceRequest {
  id           String               @id @default(uuid())
  title        String               @db.VarChar(255)
  description  String?              @db.Text
  status       ServiceRequestStatus @default(NEW)
  priority     String               @default("NORMAL") @db.VarChar(20)
  assignedToId String?
  assignedTo   User?                @relation("ServiceRequestAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(6)

  comments  ServiceRequestComment[]
  history   ServiceRequestHistory[]
  proposal  Proposal?

  @@index([clientId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([assignedToId])
}

model ServiceRequestComment {
  id               String         @id @default(uuid())
  body             String         @db.Text
  isInternal       Boolean        @default(false)
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorId         String
  author           User           @relation("ServiceRequestCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, isInternal])
}

model ServiceRequestHistory {
  id               String         @id @default(uuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?          @relation("ServiceRequestHistoryUser", fields: [userId], references: [id], onDelete: SetNull)
  field            String         @db.VarChar(100)
  oldValue         String?        @db.VarChar(500)
  newValue         String?        @db.VarChar(500)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, createdAt])
}
model Project {
  id                String                @id @default(uuid())
  name              String                @db.VarChar(255)
  description       String?               @db.Text
  status            ProjectStatus         @default(PLANNING)
  companyId         String
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId          String?
  client            Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks             Task[]
  missions          FreelancerMission[]
  documents         Document[]
  proposals         Proposal[]
  approvals         Approval[]
  enhancedDocuments EnhancedDocument[]
  invoices          Invoice[]
  clientOnboardings ClientOnboarding[]
  archivedAt        DateTime?             @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([companyId, status])
  @@index([companyId, status, updatedAt])
  @@index([companyId, createdAt])
  @@index([clientId])
  @@index([archivedAt])
}
model Task {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  description String?     @db.Text
  status      TaskStatus  @default(TODO)
  dueDate     DateTime?   @db.Timestamptz(6)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([projectId, assigneeId])
  @@index([assigneeId])
  @@index([dueDate, status])
}
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([taskId])
  @@index([authorId])
}

// ContactRequest model for contact form submissions
model ContactRequest {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(255)
  email       String        @db.VarChar(255)
  phone       String?       @db.VarChar(50)
  serviceType String        @db.VarChar(255)
  budget      String?       @db.VarChar(255)
  company     String        @db.VarChar(255)
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}
model Skill {
  id           String               @id @default(uuid())
  name         String               @unique @db.VarChar(100)
  freelancers  FreelancerProfile[]
}

// FreelancerProfile model for freelancer details
model FreelancerProfile {
  id          String               @id @default(uuid())
  userId      String               @unique
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?              @db.Text
  hourlyRate  Decimal?             @db.Decimal(10, 2)
  availability Boolean             @default(true)
  rating      Decimal?             @db.Decimal(2, 1) // Average rating (1-5)
  reviewCount Int                  @default(0)
  skills      Skill[]
  missions    FreelancerMission[]
  portfolio   PortfolioItem[]
  applications MissionApplication[]
  ratings     FreelancerRating[]
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([userId])
  @@index([userId, createdAt])
}

// FreelancerMission model for marketplace missions
model FreelancerMission {
  id             String               @id @default(uuid())
  title          String               @db.VarChar(255)
  description    String?              @db.Text
  budget         Decimal?             @db.Decimal(10, 2)
  status         MissionStatus        @default(OPEN)
  paymentStatus  PaymentStatus        @default(UNPAID)
  paidAmount     Decimal?             @db.Decimal(12, 2)
  paidAt         DateTime?            @db.Timestamptz(6)
  paymentNote    String?              @db.Text
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freelancerId   String?
  freelancer     FreelancerProfile?   @relation(fields: [freelancerId], references: [id], onDelete: SetNull)
  projectId      String?
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  applications   MissionApplication[]
  ratings        FreelancerRating[]
  createdAt      DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([companyId, status])
  @@index([companyId, status, updatedAt])
  @@index([companyId, createdAt])
  @@index([freelancerId])
  @@index([paymentStatus])
}
model MissionApplication {
  id          String                 @id @default(uuid())
  missionId   String
  mission     FreelancerMission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer  FreelancerProfile      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  status      MissionApplicationStatus @default(PENDING)
  rating      FreelancerRating?
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(6)

  @@unique([missionId, freelancerId])
  @@index([missionId])
  @@index([freelancerId])
  @@index([missionId, status])
  @@index([missionId, createdAt])
}

// FreelancerRating model - one rating per completed mission
model FreelancerRating {
  id              String            @id @default(uuid())
  score           Int               // 1-5
  comment         String?           @db.Text
  freelancerId    String
  freelancer      FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  missionId       String
  mission         FreelancerMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  applicationId   String            @unique
  application     MissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User              @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)

  @@unique([missionId, freelancerId])
  @@index([freelancerId])
  @@index([reviewerId])
  @@index([freelancerId, score])
}
model PortfolioItem {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?        @db.Text
  url         String?        @db.VarChar(255)
  imageUrl    String?        @db.VarChar(255)
  freelancerId String
  freelancer  FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  @@index([freelancerId])
}

// Notification model for user notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt])
}
model Document {
  id        String       @id @default(uuid())
  name      String       @db.VarChar(255)
  type      DocumentType @default(OTHER)
  url       String       @db.VarChar(500)
  fileKey   String?      @db.VarChar(500)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([clientId])
  @@index([projectId])
}
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @db.VarChar(64)
  familyId  String    @db.VarChar(36)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// Freelancer Application model for join us requests
model FreelancerApplication {
  id              String            @id @default(uuid())
  firstName       String            @db.VarChar(255)
  lastName        String            @db.VarChar(255)
  email           String            @db.VarChar(255)
  phone           String?           @db.VarChar(50)
  position        String            @db.VarChar(255)
  cvUrl           String            @db.VarChar(500)
  cvKey           String?           @db.VarChar(500)
  portfolioUrl    String            @db.VarChar(500)
  portfolioKey    String?           @db.VarChar(500)
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @db.Text
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Nullable: set at submission time when known, or at acceptance time by the admin
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  accountCreatedAt DateTime?
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([companyId])
  @@index([companyId, status])
}

// Client Onboarding model
model ClientOnboarding {
  id            String           @id @default(uuid())
  projectId     String           @unique
  // Restrict (not Cascade): deleting a project must not silently destroy its onboarding
  // record. deleteProject blocks while an onboarding exists; archive the project instead.
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedUserId String?
  assignedUser  User?            @relation("ClientOnboardingAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  steps         OnboardingStep[]
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)

  @@index([projectId])
  @@index([clientId])
  @@index([companyId])
}

// Onboarding Step model
model OnboardingStep {
  id               String               @id @default(uuid())
  onboardingId     String
  onboarding       ClientOnboarding     @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  stepType         String               @db.VarChar(100)
  title            String               @db.VarChar(255)
  description      String?              @db.Text
  status           OnboardingStepStatus @default(PENDING)
  orderIndex       Int                  @default(0)
  deadline         DateTime?            @db.Timestamptz(6)
  completedAt      DateTime?            @db.Timestamptz(6)
  contract         Contract?
  payment          Payment?
  questionnaire    Questionnaire?
  specifications   Specifications?
  kickoff          KickoffMeeting?
  production       ProductionProgress?
  delivery         Delivery?
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)

  @@index([onboardingId])
  @@index([onboardingId, orderIndex])
}

// Contract model
model Contract {
  id               String           @id @default(uuid())
  onboardingStepId String           @unique
  onboardingStep   OnboardingStep   @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  contractUrl      String?          @db.VarChar(500)
  status           ContractStatus   @default(PENDING)
  signedAt         DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
}

// Payment model
model Payment {
  id               String           @id @default(uuid())
  onboardingStepId String           @unique
  onboardingStep   OnboardingStep   @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  amount           Decimal?         @db.Decimal(10, 2)
  amountPaid       Decimal?         @db.Decimal(10, 2)
  status           PaymentStatus    @default(UNPAID)
  deadline         DateTime?        @db.Timestamptz(6)
  paidAt           DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
}

// Questionnaire model
model Questionnaire {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  serviceType      String       @db.VarChar(100)
  data             Json?
  isDraft          Boolean      @default(true)
  submittedAt      DateTime?    @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Specifications model
model Specifications {
  id               String               @id @default(uuid())
  onboardingStepId String               @unique
  onboardingStep   OnboardingStep       @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  requirements     String?              @db.Text
  objectives       String?              @db.Text
  features         String?              @db.Text
  deliverables     String?              @db.Text
  timeline         String?              @db.Text
  approvalStatus   SpecApprovalStatus   @default(PENDING)
  feedback         String?              @db.Text
  approvedAt       DateTime?            @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)
}

// Kickoff Meeting model
model KickoffMeeting {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  meetingDate      DateTime?    @db.Timestamptz(6)
  participants     String?      @db.Text
  meetingLink      String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Production Progress model
model ProductionProgress {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  analysis         Int          @default(0)
  design           Int          @default(0)
  development      Int          @default(0)
  testing          Int          @default(0)
  deployment       Int          @default(0)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Delivery model
model Delivery {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  deliverables     String?      @db.Text
  documentation    String?      @db.VarChar(500)
  accessDetails    String?      @db.Text
  userGuides       String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Proposal Center
enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Proposal {
  id               String         @id @default(uuid())
  title            String         @db.VarChar(255)
  description      String?        @db.Text
  status           ProposalStatus @default(DRAFT)
  version          Int            @default(1)
  amount           Decimal?       @db.Decimal(12, 2)
  currency         String         @default("EUR") @db.VarChar(10)
  expiresAt        DateTime?      @db.Timestamptz(6)
  viewedAt         DateTime?      @db.Timestamptz(6)
  acceptedAt       DateTime?      @db.Timestamptz(6)
  rejectedAt       DateTime?      @db.Timestamptz(6)
  pdfUrl           String?        @db.VarChar(500)
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceRequestId String?         @unique
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  sections         ProposalSection[]
  history          ProposalHistory[]
  invoice          Invoice?
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([companyId, status])
  @@index([serviceRequestId])
}

model ProposalSection {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  content     String?  @db.Text
  orderIndex  Int      @default(0)
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([proposalId])
  @@index([proposalId, orderIndex])
}

model ProposalHistory {
  id          String   @id @default(uuid())
  action      String   @db.VarChar(100)
  comment     String?  @db.Text
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([proposalId])
  @@index([proposalId, createdAt])
}

// Approval Center
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  COMMENTED
}

model Approval {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?        @db.Text
  status      ApprovalStatus @default(PENDING)
  dueDate     DateTime?      @db.Timestamptz(6)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachments ApprovalAttachment[]
  timeline    ApprovalTimeline[]
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@index([companyId, status])
}

model ApprovalAttachment {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  url         String   @db.VarChar(500)
  approvalId  String
  approval    Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([approvalId])
}

model ApprovalTimeline {
  id          String         @id @default(uuid())
  action      String         @db.VarChar(100)
  comment     String?        @db.Text
  status      ApprovalStatus
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  approvalId  String
  approval    Approval       @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)

  @@index([approvalId])
  @@index([approvalId, createdAt])
}

// Document Center (Enhanced)
enum EnhancedDocumentType {
  CONTRACT
  DELIVERABLE
  GUIDE
  REPORT
  INVOICE
  OTHER
}

enum DocumentAccessLevel {
  ADMIN_ONLY
  ADMIN_FREELANCER
  CLIENT_ADMIN
  ALL
}

model EnhancedDocument {
  id          String               @id @default(uuid())
  name        String               @db.VarChar(255)
  description String?              @db.Text
  type        EnhancedDocumentType @default(OTHER)
  url         String               @db.VarChar(500)
  fileKey     String?              @db.VarChar(500)
  version     Int                  @default(1)
  parentId    String?
  parent      EnhancedDocument?    @relation("DocumentVersioning", fields: [parentId], references: [id], onDelete: SetNull)
  children    EnhancedDocument[]   @relation("DocumentVersioning")
  tags        String[]
  accessLevel DocumentAccessLevel  @default(CLIENT_ADMIN)
  clientId    String?
  client      Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  accessLog   DocumentAccessLog[]
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId])
  @@index([type])
  @@index([tags])
  @@index([createdAt])
  @@index([companyId, type])
}

model DocumentAccessLog {
  id          String           @id @default(uuid())
  action      String           @db.VarChar(100)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  documentId  String
  document    EnhancedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ipAddress   String?          @db.VarChar(45)
  userAgent   String?          @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)

  @@index([documentId])
  @@index([userId])
  @@index([documentId, createdAt])
}

// Invoice Center
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Invoice {
  id                String        @id @default(uuid())
  number            String        @db.VarChar(100)
  title             String        @db.VarChar(255)
  description       String?       @db.Text
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("EUR") @db.VarChar(10)
  amountPaid        Decimal       @default(0) @db.Decimal(12, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime?     @db.Timestamptz(6)
  sentAt            DateTime?     @db.Timestamptz(6)
  paidAt            DateTime?     @db.Timestamptz(6)
  pdfUrl            String?       @db.VarChar(500)
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  proposalId        String?       @unique
  proposal          Proposal?     @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  items             InvoiceItem[]
  payments          InvoicePayment[]
  reminders         InvoiceReminder[]
  creditNotes       CreditNote[]
  createdAt         DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, status, createdAt])
  @@index([number])
}

// A credit note records money owed back to a client — issued for an overpayment or as a
// correction against an invoice. Issuing one increments Client.creditBalance.
model CreditNote {
  id        String   @id @default(uuid())
  number    String   @db.VarChar(100)
  amount    Decimal  @db.Decimal(12, 2)
  reason    String   @db.Text
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([companyId, number])
  @@index([invoiceId])
  @@index([clientId])
  @@index([companyId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  description String   @db.VarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

model InvoicePayment {
  id           String   @id @default(uuid())
  amount       Decimal  @db.Decimal(12, 2)
  method       String?  @db.VarChar(100)
  reference    String?  @db.VarChar(255)
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedById String?
  recordedBy   User?    @relation("RecordedInvoicePayments", fields: [recordedById], references: [id], onDelete: SetNull)
  paidAt       DateTime @default(now()) @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([recordedById])
}

model InvoiceReminder {
  id          String   @id @default(uuid())
  type        String   @db.VarChar(100)
  sentAt      DateTime @default(now()) @db.Timestamptz(6)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

// Client Success Center
model ClientSuccess {
  id              String             @id @default(uuid())
  clientId        String             @unique
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  score           Int                @default(0)
  objectives      SuccessObjective[]
  metrics         SuccessMetric[]
  recommendations SuccessRecommendation[]
  timeline        SuccessTimeline[]
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId])
}

model SuccessObjective {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(255)
  description    String?       @db.Text
  targetValue    Decimal?      @db.Decimal(12, 2)
  currentValue   Decimal?      @db.Decimal(12, 2)
  unit           String?       @db.VarChar(50)
  targetDate     DateTime?     @db.Timestamptz(6)
  completedAt    DateTime?     @db.Timestamptz(6)
  successId      String
  success        ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model SuccessMetric {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  initialValue Decimal       @db.Decimal(12, 2)
  currentValue Decimal       @db.Decimal(12, 2)
  unit         String?       @db.VarChar(50)
  successId    String
  success      ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  history      MetricHistory[]
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model MetricHistory {
  id        String        @id @default(uuid())
  value     Decimal       @db.Decimal(12, 2)
  date      DateTime      @default(now()) @db.Timestamptz(6)
  metricId  String
  metric    SuccessMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)

  @@index([metricId])
  @@index([metricId, date])
}

model SuccessRecommendation {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(255)
  description String?       @db.Text
  priority    Int           @default(0)
  status      String        @default("PENDING") @db.VarChar(50)
  successId   String
  success     ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, priority])
}

model SuccessTimeline {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(255)
  description String?       @db.Text
  eventType   String        @db.VarChar(100)
  date        DateTime      @default(now()) @db.Timestamptz(6)
  successId   String
  success     ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, date])
}

// AI Conversation history — persisted per user + company
enum AiMessageRole {
  user
  assistant
}

model AiConversation {
  id        String      @id @default(uuid())
  title     String      @db.VarChar(255)
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)

  @@index([companyId, userId])
  @@index([companyId, userId, createdAt])
}

model AiMessage {
  id             String         @id @default(uuid())
  role           AiMessageRole
  content        String         @db.Text
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// Custom question asked by a logged-in user from the FAQ section
model CustomQuestion {
  id        String                  @id @default(uuid())
  subject   String                  @db.VarChar(255)
  status    CustomQuestionStatus    @default(OPEN)
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?                @relation(fields: [companyId], references: [id], onDelete: SetNull)
  messages  CustomQuestionMessage[]
  createdAt DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt DateTime                @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

// A single message within a custom question conversation thread
model CustomQuestionMessage {
  id         String         @id @default(uuid())
  content    String         @db.Text
  authorRole Role
  authorId   String
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questionId String
  question   CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)

  @@index([questionId])
  @@index([questionId, createdAt])
}
