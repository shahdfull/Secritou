generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role definitions
enum Role {
  ADMIN
  MANAGER
  CLIENT
  FREELANCER
}

// Status of a custom question asked from the FAQ
enum CustomQuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

// Project status options. No CANCELLED value: an abandoned project is represented via
// archivedAt/deletedAt instead of a terminal status, mirroring how it's already excluded
// from every "active projects" query (status: {notIn: ["COMPLETED"]}, archivedAt: null).
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

// Task status options. No CANCELLED value, unlike ProjectStatus there is no archivedAt/
// deletedAt equivalent for a Task — an abandoned task must be deleted (deleteTask) rather
// than marked cancelled, since there's no soft-delete/archive mechanism at the Task level.
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// Recurring meeting cadence for a project's check-ins (e.g. weekly client sync).
// NONE means no recurring meeting is scheduled for this project.
enum MeetingFrequency {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// Lead status options for sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

// Contact request status options
enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

// Freelancer Application status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Client Onboarding Step Status
enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// Contract Status
enum ContractStatus {
  PENDING
  SIGNED
}

// Payment Status
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Specification Approval Status
enum SpecApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Service request status options
enum ServiceRequestStatus {
  NEW
  IN_REVIEW
  IN_PROGRESS
  WAITING_CLIENT
  COMPLETED
  CANCELLED
}

enum ServiceRequestType {
  SUPPORT
  NEW_PROJECT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Single-tenant Company model (one record for Secritou)
model Company {
  id              String   @id @default(uuid())
  singleton       Boolean  @default(true)
  name            String   @db.VarChar(255)
  website         String?  @db.VarChar(255)
  logoUrl         String?  @db.VarChar(255)
  primaryColor    String?  @db.VarChar(20)
  // Tunisian tax identifier (matricule fiscal), required on invoices for legal opposability.
  matriculeFiscal String?  @db.VarChar(50)
  address         String?  @db.VarChar(500)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  @@unique([singleton])
}

// User model for all platform users
model User {
  id                          String                   @id @default(uuid())
  email                       String                   @db.VarChar(255)
  name                        String                   @db.VarChar(255)
  phone                       String?                  @db.VarChar(50)
  passwordHash                String                   @db.VarChar(255)
  role                        Role                     @default(CLIENT)
  mustChangePassword          Boolean                  @default(false)
  clientId                    String?
  client                      Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId                   String?
  service                     Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks                       Task[]                   @relation("AssignedTasks")
  comments                    Comment[]
  refreshTokens               RefreshToken[]
  freelancerProfile           FreelancerProfile?
  notifications               Notification[]
  resetToken                  String?                  @db.VarChar(255)
  resetTokenExpiry            DateTime?                @db.Timestamptz(6)
  // Email-change confirmation: the new address is staged here (not written to `email`) until
  // the user clicks the confirmation link sent to that new address — prevents an attacker with
  // a stolen session from silently taking over the account's email without proving control of
  // the new inbox.
  pendingEmail                String?                  @db.VarChar(255)
  emailChangeTokenHash        String?                  @db.VarChar(255)
  emailChangeTokenExpiry      DateTime?                @db.Timestamptz(6)
  freelancerApplications      FreelancerApplication[]
  clientOnboardingsAsAssignee ClientOnboarding[]       @relation("ClientOnboardingAssignedUser")
  proposalHistories           ProposalHistory[]
  approvalTimelines           ApprovalTimeline[]
  documentAccessLogs          DocumentAccessLog[]
  assignedServiceRequests     ServiceRequestComment[]  @relation("ServiceRequestCommentAuthor")
  serviceRequestHistory       ServiceRequestHistory[]  @relation("ServiceRequestHistoryUser")
  serviceRequestAssignments   ServiceRequest[]         @relation("ServiceRequestAssignee")
  recordedPayments            Payment[]                @relation("RecordedPayments")
  projectMeetings             ProjectMeeting[]
  aiConversations             AiConversation[]
  customQuestions             CustomQuestion[]
  customQuestionMessages      CustomQuestionMessage[]
  managerPermission           ManagerPermission?
  uploadedDocuments           Document[]               @relation("UploadedDocuments")
  signedDocuments             Document[]               @relation("SignedDocuments")
  projectClientApprovals      Project[]                @relation("ProjectClientApprovals")
  assignedLeads               Lead[]                   @relation("ManagerLeads")
  givenRatings                Rating[]                 @relation("RatedByUser")
  timeEntries                 TimeEntry[]
  commissionSplits            ProjectCommissionSplit[] @relation("PartnerCommissionSplits")
  commissions                 Commission[]             @relation("PartnerCommissions")
  connectedGscConnections     GscConnection[]
  sessions                    UserSession[]
  lastLoginAt                 DateTime?                @db.Timestamptz(6)
  createdAt                   DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt                   DateTime                 @updatedAt @db.Timestamptz(6)

  @@unique([email])
  // Indexes for faster queries
  @@index([clientId])
  @@index([email])
  @@index([resetToken])
  @@index([emailChangeTokenHash])
  @@index([serviceId])
}

// Tracks connected-time via a heartbeat ping from the authenticated back-office UI
// (see POST /users/me/heartbeat). A session is "active" while lastHeartbeatAt is
// recent; the maintenance job closes stale sessions (no heartbeat for
// SESSION_IDLE_TIMEOUT_MINUTES) by leaving lastHeartbeatAt as the effective end time —
// duration = lastHeartbeatAt - startedAt. This approximates real usage time (tab open +
// focused) rather than login-to-logout, which would overcount idle/background tabs.
model UserSession {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt       DateTime  @default(now()) @db.Timestamptz(6)
  lastHeartbeatAt DateTime  @default(now()) @db.Timestamptz(6)
  closedAt        DateTime? @db.Timestamptz(6)

  @@index([userId])
  @@index([lastHeartbeatAt])
}

// Service (business pole/department) : e.g. "Technology Solutions", "AI & Automation".
// Leads, clients and users are attached to a service so MANAGERs can be scoped to their pole.
model Service {
  id        String            @id @default(uuid())
  name      String            @unique @db.VarChar(100)
  leads     Lead[]
  projects  Project[]
  users     User[]
  clients   Client[]
  templates ProjectTemplate[]
  createdAt DateTime          @default(now()) @db.Timestamptz(6)
}

// One reusable task checklist per pole — applied on demand from a project's empty-tasks
// state, not auto-injected at project creation (which is proposal-driven, not a form).
// Deliberately one template per Service for now, not a full template-management system.
model ProjectTemplate {
  id        String         @id @default(uuid())
  serviceId String         @unique
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String         @db.VarChar(255)
  tasks     TaskTemplate[]
  createdAt DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @db.Timestamptz(6)
}

model TaskTemplate {
  id          String          @id @default(uuid())
  templateId  String
  template    ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String          @db.VarChar(255)
  description String?         @db.Text
  orderIndex  Int             @default(0)

  @@index([templateId, orderIndex])
}

// Lead model for potential clients/sales pipeline
model Lead {
  id                String          @id @default(uuid())
  name              String          @db.VarChar(255)
  email             String?         @db.VarChar(255)
  phone             String?         @db.VarChar(50)
  source            String?         @db.VarChar(100)
  status            LeadStatus      @default(NEW)
  notes             String?         @db.Text
  serviceId         String?
  service           Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  convertedClientId String?
  convertedClient   Client?         @relation("ConvertedLead", fields: [convertedClientId], references: [id], onDelete: SetNull)
  archivedAt        DateTime?       @db.Timestamptz(6)
  sourceContactId   String?         @unique
  sourceContact     ContactRequest? @relation(fields: [sourceContactId], references: [id])
  assignedManagerId String?
  assignedManager   User?           @relation("ManagerLeads", fields: [assignedManagerId], references: [id])
  department        String?         @db.VarChar(255)
  lostReason        String?         @db.VarChar(500)
  proposal          Proposal?
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email])
  @@index([archivedAt])
  @@index([serviceId])
}

// Archive copy of "Lead" rows written by archiveColdData()
// (server/src/jobs/processors/maintenance.processor.ts) via raw SQL only —
// never read/written through Prisma Client. @@ignore keeps it out of the
// generated client while still satisfying `prisma migrate diff` against
// migration.sql (see ANOMALIES.yaml SEC-016). Partitioned by createdAt in
// migration.sql; the composite id+createdAt key is required because
// Postgres range-partitioned tables must include the partition column in
// every unique/primary key.
// Field order below matches "Lead"'s actual physical column order in Postgres
// (verified via information_schema.columns, not schema.prisma's own field-declaration
// order for the Lead model above) — required because the archive job does a positional
// `INSERT ... SELECT *`, not an order-independent by-name insert. See SEC-020.
model LeadArchive {
  id                String
  name              String     @db.VarChar(255)
  email             String?    @db.VarChar(255)
  phone             String?    @db.VarChar(50)
  source            String?    @db.VarChar(100)
  status            LeadStatus @default(NEW)
  notes             String?    @db.Text
  serviceId         String?
  convertedClientId String?
  archivedAt        DateTime?  @db.Timestamptz(6)
  sourceContactId   String?
  assignedManagerId String?
  department        String?    @db.VarChar(255)
  createdAt         DateTime   @db.Timestamptz(6)
  updatedAt         DateTime   @db.Timestamptz(6)
  lostReason        String?    @db.VarChar(500)

  @@id([id, createdAt])
  @@ignore
}

// Archive copy of "ContactRequest" rows written by archiveColdData() — see
// LeadArchive above for the full rationale (SEC-016).
model ContactRequestArchive {
  id          String
  name        String        @db.VarChar(255)
  email       String        @db.VarChar(255)
  phone       String?       @db.VarChar(50)
  serviceType String        @db.VarChar(255)
  budget      String?       @db.VarChar(255)
  company     String        @db.VarChar(255)
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  convertedAt DateTime?     @db.Timestamptz(6)
  createdAt   DateTime      @db.Timestamptz(6)
  updatedAt   DateTime      @db.Timestamptz(6)

  @@id([id, createdAt])
  @@ignore
}

// Client model for paying/active clients
model Client {
  id                String             @id @default(uuid())
  name              String             @db.VarChar(255)
  email             String?            @db.VarChar(255)
  phone             String?            @db.VarChar(50)
  projects          Project[]
  users             User[]
  serviceRequests   ServiceRequest[]
  documents         Document[]
  proposals         Proposal[]
  approvals         Approval[]
  invoices          Invoice[]
  creditNotes       CreditNote[]
  creditBalance     Decimal            @default(0) @db.Decimal(14, 3)
  clientSuccess     ClientSuccess?
  clientOnboardings ClientOnboarding[]
  serviceId         String?
  service           Service?           @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  convertedLeads    Lead[]             @relation("ConvertedLead")
  // Cadrage §6: "paiement 1re tranche = ouverture de l'espace client" — set only when the
  // deposit invoice for this client's first project actually reaches PAID (invoice.service.ts
  // addPayment). Null means the client account exists (created at proposal acceptance so the
  // invitation email/welcome flow works) but portal access itself is not yet unlocked.
  portalActivatedAt DateTime?          @db.Timestamptz(6)
  archivedAt        DateTime?          @db.Timestamptz(6)
  deletedAt         DateTime?          @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  gscConnection     GscConnection?
  metricSnapshots   MetricSnapshot[]

  @@unique([email])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([serviceId])
}

// Source system a MetricSnapshot was pulled from. Starts with Search Console;
// GA4/Meta/Google Ads are additional sources under the same generic model.
enum MetricSource {
  GSC
  GA4
  META
  GADS
}

// A client's connection to a Google Search Console property, connected by an
// ADMIN/MANAGER on the client's behalf (per-client OAuth consent, not a shared
// service account). Refresh token is encrypted at rest (see utils/encryption.ts) —
// never store it or the access token in plaintext.
model GscConnection {
  id                    String    @id @default(uuid())
  clientId              String    @unique
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // The Search Console property URL (e.g. "sc-domain:example.com" or "https://example.com/").
  siteUrl               String    @db.VarChar(500)
  encryptedRefreshToken String    @db.Text
  // Short-lived access token cache — always re-derivable from the refresh token, so it's
  // fine to drop this without data loss; kept only to avoid refreshing on every job run.
  encryptedAccessToken  String?   @db.Text
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  connectedById         String
  connectedBy           User      @relation(fields: [connectedById], references: [id], onDelete: Restrict)
  lastSyncedAt          DateTime? @db.Timestamptz(6)
  lastSyncError         String?   @db.Text
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  @@index([clientId])
}

// Generic external-performance-data model (SEO/traffic/ads metrics), one row per
// (client, source, metric, period). Deliberately source-agnostic so GA4/Meta/Google
// Ads can reuse it without a schema change — only the connector differs.
model MetricSnapshot {
  id          String       @id @default(uuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  source      MetricSource
  // e.g. "clicks", "impressions", "ctr", "position" (GSC); "sessions", "conversions" (GA4).
  metric      String       @db.VarChar(100)
  value       Decimal      @db.Decimal(18, 6)
  // Dimension the value is broken down by (e.g. a specific query or page URL).
  // Empty string means the value is aggregated across the whole property for this
  // period — kept non-nullable so the compound unique constraint below is usable in
  // upserts (Prisma's compound-unique lookups cannot target a NULL column value).
  dimension   String       @default("") @db.VarChar(500)
  periodStart DateTime     @db.Timestamptz(6)
  periodEnd   DateTime     @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([clientId, source, metric, dimension, periodStart, periodEnd])
  @@index([clientId, source, metric])
  @@index([periodStart])
}

model ServiceRequest {
  id           String               @id @default(uuid())
  title        String               @db.VarChar(255)
  description  String?              @db.Text
  type         ServiceRequestType   @default(NEW_PROJECT)
  status       ServiceRequestStatus @default(NEW)
  priority     Priority             @default(NORMAL)
  assignedToId String?
  assignedTo   User?                @relation("ServiceRequestAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(6)

  comments ServiceRequestComment[]
  history  ServiceRequestHistory[]
  proposal Proposal?

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([assignedToId])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  booking   Booking?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
}

model Booking {
  id        String           @id @default(cuid())
  slotId    String           @unique
  slot      AvailabilitySlot @relation(fields: [slotId], references: [id])
  name      String
  email     String
  phone     String?
  notes     String?
  status    String           @default("CONFIRMED")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([email])
}

model ServiceRequestComment {
  id               String         @id @default(uuid())
  body             String         @db.Text
  isInternal       Boolean        @default(false)
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?          @relation("ServiceRequestCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, isInternal])
}

model ServiceRequestHistory {
  id               String         @id @default(uuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?          @relation("ServiceRequestHistoryUser", fields: [userId], references: [id], onDelete: SetNull)
  field            String         @db.VarChar(100)
  oldValue         String?        @db.VarChar(500)
  newValue         String?        @db.VarChar(500)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, createdAt])
}

model Project {
  id                 String                   @id @default(uuid())
  name               String                   @db.VarChar(255)
  description        String?                  @db.Text
  status             ProjectStatus            @default(PLANNING)
  clientId           String?
  client             Client?                  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId          String?
  service            Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks              Task[]
  timeEntries        TimeEntry[]
  documents          Document[]
  proposals          Proposal[]               @relation("ProjectProposals")
  proposalId         String?                  @unique
  proposal           Proposal?                @relation("ProjectProposal", fields: [proposalId], references: [id])
  approvals          Approval[]
  invoices           Invoice[]
  commissionSplits   ProjectCommissionSplit[]
  commissions        Commission[]
  metricSnapshots    MetricSnapshot[]
  clientOnboardings  ClientOnboarding[]
  meetings           ProjectMeeting[]
  // Recurring meeting cadence — NONE (default) means no reminder job tracks this project.
  meetingFrequency   MeetingFrequency         @default(NONE)
  nextMeetingDate    DateTime?                @db.Timestamptz(6)
  // Snapshot from the accepted proposal (budget is free-text like Project elsewhere; deadline
  // mirrors the proposal's expiry). Filled by the acceptance cascade, editable afterwards.
  budget             String?                  @db.VarChar(255)
  deadline           DateTime?                @db.Timestamptz(6)
  // Client brief questionnaire
  serviceType        String?                  @db.VarChar(50)
  briefData          Json?
  briefCompleted     Boolean                  @default(false)
  briefCompletedAt   DateTime?                @db.Timestamptz(6)
  // Client final approval (triggers COMPLETED + balance invoice)
  clientApprovedAt   DateTime?                @db.Timestamptz(6)
  clientApprovedById String?
  clientApprovedBy   User?                    @relation("ProjectClientApprovals", fields: [clientApprovedById], references: [id], onDelete: SetNull)
  archivedAt         DateTime?                @db.Timestamptz(6)
  deletedAt          DateTime?                @db.Timestamptz(6)
  createdAt          DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([status, updatedAt])
  @@index([createdAt])
  @@index([clientId])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([serviceId])
  @@index([nextMeetingDate])
  // Supports healthBoardRepository.getActiveProjectsHealth (live Health Board screen) and
  // checkOverdueDeadlines (daily cron) — both filter active, non-archived projects by deadline.
  @@index([status, archivedAt, deadline])
}

model Task {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  description String?     @db.Text
  status      TaskStatus  @default(TODO)
  priority    Priority    @default(NORMAL)
  // Assignment window used for freelancer double-booking checks (overlap = [startDate, dueDate]
  // intersecting another task assigned to the same freelancer). startDate is optional so existing
  // tasks with only a dueDate keep working; a task without a startDate is never checked for overlap.
  startDate   DateTime?   @db.Timestamptz(6)
  dueDate     DateTime?   @db.Timestamptz(6)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]
  timeEntries TimeEntry[]
  // SEC-060: attachments directly on a task (distinct from a project-level Document) — Document
  // already supports an optional projectId, taskId follows the same optional-FK pattern.
  documents   Document[]
  // SEC-060 (sous-tâches, décision du porteur 2026-07-19): a checklist, not a nested Task — a
  // single flat level, no independent assignee/status/dueDate. TaskChecklistItem is a distinct,
  // lighter model rather than a self-referencing Task.parentId, to avoid implying a subtask is a
  // full task (which the porteur explicitly ruled out).
  checklistItems TaskChecklistItem[]
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([projectId, assigneeId])
  @@index([assigneeId])
  @@index([dueDate, status])
  // Supports checkTaskDeadlines/checkOverdueTasks (ceoAlerts.processor.ts), which filter by
  // dueDate+status then resolve the assignee for each matching task.
  @@index([assigneeId, dueDate])
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([taskId])
  @@index([authorId])
}

// SEC-060 (sous-tâches, item 4 du constat P1 rapport Product Owner) : une checklist plate sur une
// tâche — pas une Task imbriquée. Décision du porteur (session 2026-07-19) : un seul niveau,
// aucun assignee/statut/échéance propre (juste titre + fait/pas fait), aucune règle de complétion
// automatique du parent.
model TaskChecklistItem {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(255)
  done      Boolean  @default(false)
  position  Int
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([taskId, position])
}

// ContactRequest model for contact form submissions
model ContactRequest {
  id            String        @id @default(uuid())
  name          String        @db.VarChar(255)
  email         String        @db.VarChar(255)
  phone         String?       @db.VarChar(50)
  serviceType   String        @db.VarChar(255)
  budget        String?       @db.VarChar(255)
  company       String        @db.VarChar(255)
  message       String        @db.Text
  status        ContactStatus @default(NEW)
  convertedLead Lead?
  convertedAt   DateTime?     @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model AnalyticsEvent {
