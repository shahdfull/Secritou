generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role definitions
enum Role {
  ADMIN
  MANAGER
  CLIENT
  FREELANCER
}

// Project status options
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

// Task status options
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// Lead status options for sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

// Contact request status options
enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

// Mission status options for freelancer marketplace
enum MissionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Mission Application status
enum MissionApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Freelancer Application status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Client Onboarding Step Status
enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// Contract Status
enum ContractStatus {
  PENDING
  SIGNED
}

// Payment Status
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Specification Approval Status
enum SpecApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Service request status options
enum ServiceRequestStatus {
  NEW
  IN_PROGRESS
  DONE
}

// Document type options
enum DocumentType {
  INVOICE
  CONTRACT
  OTHER
}

// Multi-tenant Company model
model Company {
  id        String                @id @default(uuid())
  name      String                @db.VarChar(255)
  website   String?               @db.VarChar(255)
  logoUrl   String?               @db.VarChar(255)
  primaryColor String?            @db.VarChar(20)
  users     User[]
  leads     Lead[]
  clients   Client[]
  projects  Project[]
  missions  FreelancerMission[]
  serviceRequests ServiceRequest[]
  documents Document[]
  createdAt DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt DateTime              @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([name])
}

// User model for all platform users
model User {
  id                  String               @id @default(uuid())
  email               String               @unique @db.VarChar(255)
  name                String               @db.VarChar(255)
  passwordHash        String               @db.VarChar(255)
  role                Role                 @default(CLIENT)
  mustChangePassword  Boolean              @default(false)
  companyId           String?
  company             Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId            String?
  client              Client?              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks               Task[]               @relation("AssignedTasks")
  comments            Comment[]
  refreshTokens       RefreshToken[]
  freelancerProfile FreelancerProfile?
  notifications Notification[]
  resetToken String? @db.VarChar(255)
  resetTokenExpiry DateTime? @db.Timestamptz(6)
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([companyId])
  @@index([clientId])
  @@index([email])
  @@index([companyId, role])
  @@index([resetToken])
  @@index([companyId, createdAt])
}

// Lead model for potential clients/sales pipeline
model Lead {
  id                String     @id @default(uuid())
  name              String     @db.VarChar(255)
  email             String?    @db.VarChar(255)
  phone             String?    @db.VarChar(50)
  source            String?    @db.VarChar(100)
  status            LeadStatus @default(NEW)
  notes             String?    @db.Text
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  convertedClientId String?
  archivedAt        DateTime?  @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)

  @@unique([companyId, email])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
  @@index([email])
  @@index([archivedAt])
}

// Client model for paying/active clients
model Client {
  id               String           @id @default(uuid())
  name             String           @db.VarChar(255)
  email            String?          @db.VarChar(255)
  phone            String?          @db.VarChar(50)
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects         Project[]
  users            User[]
  serviceRequests  ServiceRequest[]
  documents        Document[]
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([companyId, email])
  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([email])
}
model ServiceRequest {
  id          String               @id @default(uuid())
  title       String               @db.VarChar(255)
  description String?              @db.Text
  status      ServiceRequestStatus @default(NEW)
  clientId    String
  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, status, createdAt])
}
model Project {
  id          String                @id @default(uuid())
  name        String                @db.VarChar(255)
  description String?               @db.Text
  status      ProjectStatus         @default(PLANNING)
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks       Task[]
  missions    FreelancerMission[]
  documents   Document[]
  createdAt   DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime              @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([companyId, status])
  @@index([companyId, status, updatedAt])
  @@index([companyId, createdAt])
  @@index([clientId])
}
model Task {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  description String?     @db.Text
  status      TaskStatus  @default(TODO)
  dueDate     DateTime?   @db.Timestamptz(6)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([projectId, assigneeId])
  @@index([assigneeId])
  @@index([dueDate, status])
}
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([taskId])
  @@index([authorId])
}

// ContactRequest model for contact form submissions
model ContactRequest {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(255)
  email       String        @db.VarChar(255)
  phone       String?       @db.VarChar(50)
  serviceType String        @db.VarChar(255)
  budget      String?       @db.VarChar(255)
  company     String        @db.VarChar(255)
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}
model Skill {
  id           String               @id @default(uuid())
  name         String               @unique @db.VarChar(100)
  freelancers  FreelancerProfile[]
}

// FreelancerProfile model for freelancer details
model FreelancerProfile {
  id          String               @id @default(uuid())
  userId      String               @unique
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?              @db.Text
  hourlyRate  Decimal?             @db.Decimal(10, 2)
  availability Boolean             @default(true)
  rating      Decimal?             @db.Decimal(2, 1) // Average rating (1-5)
  reviewCount Int                  @default(0)
  skills      Skill[]
  missions    FreelancerMission[]
  portfolio   PortfolioItem[]
  applications MissionApplication[]
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([userId])
  @@index([userId, createdAt])
}

// FreelancerMission model for marketplace missions
model FreelancerMission {
  id          String               @id @default(uuid())
  title       String               @db.VarChar(255)
  description String?              @db.Text
  budget      Decimal?             @db.Decimal(10, 2)
  status      MissionStatus        @default(OPEN)
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  freelancerId String?
  freelancer  FreelancerProfile?   @relation(fields: [freelancerId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  applications MissionApplication[]
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([companyId, status])
  @@index([companyId, status, updatedAt])
  @@index([companyId, createdAt])
  @@index([freelancerId])
}
model MissionApplication {
  id          String                 @id @default(uuid())
  missionId   String
  mission     FreelancerMission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  freelancerId String
  freelancer  FreelancerProfile      @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  status      MissionApplicationStatus @default(PENDING)
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(6)

  @@unique([missionId, freelancerId])
  @@index([missionId])
  @@index([freelancerId])
  @@index([missionId, status])
  @@index([missionId, createdAt])
}
model PortfolioItem {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?        @db.Text
  url         String?        @db.VarChar(255)
  imageUrl    String?        @db.VarChar(255)
  freelancerId String
  freelancer  FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  @@index([freelancerId])
}

// Notification model for user notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}
model Document {
  id        String       @id @default(uuid())
  name      String       @db.VarChar(255)
  type      DocumentType @default(OTHER)
  url       String       @db.VarChar(500)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([clientId])
  @@index([projectId])
}
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @db.VarChar(64)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
}

// Freelancer Application model for join us requests
model FreelancerApplication {
  id              String            @id @default(uuid())
  firstName       String            @db.VarChar(255)
  lastName        String            @db.VarChar(255)
  email           String            @db.VarChar(255)
  phone           String?           @db.VarChar(50)
  position        String            @db.VarChar(255)
  cvUrl           String            @db.VarChar(500)
  portfolioUrl    String            @db.VarChar(500)
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @db.Text
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

// Client Onboarding model
model ClientOnboarding {
  id            String           @id @default(uuid())
  projectId     String           @unique
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedUserId String?
  assignedUser  User?            @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  steps         OnboardingStep[]
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)

  @@index([projectId])
  @@index([clientId])
  @@index([companyId])
}

// Onboarding Step model
model OnboardingStep {
  id               String               @id @default(uuid())
  onboardingId     String
  onboarding       ClientOnboarding     @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  stepType         String               @db.VarChar(100)
  title            String               @db.VarChar(255)
  description      String?              @db.Text
  status           OnboardingStepStatus @default(PENDING)
  orderIndex       Int                  @default(0)
  deadline         DateTime?            @db.Timestamptz(6)
  completedAt      DateTime?            @db.Timestamptz(6)
  contract         Contract?
  payment          Payment?
  questionnaire    Questionnaire?
  specifications   Specifications?
  kickoff          KickoffMeeting?
  production       ProductionProgress?
  delivery         Delivery?
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)

  @@index([onboardingId])
  @@index([onboardingId, orderIndex])
}

// Contract model
model Contract {
  id               String           @id @default(uuid())
  onboardingStepId String           @unique
  onboardingStep   OnboardingStep   @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  contractUrl      String?          @db.VarChar(500)
  status           ContractStatus   @default(PENDING)
  signedAt         DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
}

// Payment model
model Payment {
  id               String           @id @default(uuid())
  onboardingStepId String           @unique
  onboardingStep   OnboardingStep   @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  amount           Decimal?         @db.Decimal(10, 2)
  amountPaid       Decimal?         @db.Decimal(10, 2)
  status           PaymentStatus    @default(UNPAID)
  deadline         DateTime?        @db.Timestamptz(6)
  paidAt           DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
}

// Questionnaire model
model Questionnaire {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  serviceType      String       @db.VarChar(100)
  data             Json?
  isDraft          Boolean      @default(true)
  submittedAt      DateTime?    @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Specifications model
model Specifications {
  id               String               @id @default(uuid())
  onboardingStepId String               @unique
  onboardingStep   OnboardingStep       @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  requirements     String?              @db.Text
  objectives       String?              @db.Text
  features         String?              @db.Text
  deliverables     String?              @db.Text
  timeline         String?              @db.Text
  approvalStatus   SpecApprovalStatus   @default(PENDING)
  feedback         String?              @db.Text
  approvedAt       DateTime?            @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)
}

// Kickoff Meeting model
model KickoffMeeting {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  meetingDate      DateTime?    @db.Timestamptz(6)
  participants     String?      @db.Text
  meetingLink      String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Production Progress model
model ProductionProgress {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  analysis         Int          @default(0)
  design           Int          @default(0)
  development      Int          @default(0)
  testing          Int          @default(0)
  deployment       Int          @default(0)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Delivery model
model Delivery {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  deliverables     String?      @db.Text
  documentation    String?      @db.VarChar(500)
  accessDetails    String?      @db.Text
  userGuides       String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}
