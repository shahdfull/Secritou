// Document Center
enum DocumentType {
  WELCOME_LETTER
  CONTRACT
  SPECS
  CLIENT_BRIEF
  QUOTE
  INVOICE_DEPOSIT
  INVOICE_BALANCE
  ROADMAP
  DELIVERABLE
  GUIDE
  REPORT
  INVOICE
  OTHER
}

enum DocumentAccessLevel {
  ADMIN_ONLY
  ADMIN_FREELANCER
  CLIENT_ADMIN
  ALL
}

model DocumentAccessLog {
  id         String   @id @default(uuid())
  action     String   @db.VarChar(100)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([documentId])
  @@index([userId])
  @@index([documentId, createdAt])
}

// Invoice Center
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

// Differentiates automatically-created deposit/balance invoices from manual ones.
// Used as a reliable duplicate guard instead of string-matching on title.
enum InvoiceType {
  STANDARD
  DEPOSIT
  BALANCE
}

// Per-month sequential counter for gapless invoice numbering (INV-YYYYMM-NNNN).
// Incremented inside the same transaction that creates the Invoice row so no
// number is ever allocated without a corresponding invoice being persisted.
model InvoiceCounter {
  prefix String @id @db.VarChar(20)
  value  Int    @default(0)
}

model Invoice {
  id                 String            @id @default(uuid())
  number             String            @unique @db.VarChar(100)
  title              String            @db.VarChar(255)
  description        String?           @db.Text
  amount             Decimal           @db.Decimal(14, 3)
  // VAT breakdown (nullable: only populated for invoices generated from a proposal amount;
  // invoices built purely from line items keep deriving `amount` via recomputeInvoiceAmount).
  amountHT           Decimal?          @db.Decimal(14, 3)
  tvaRate            Decimal?          @db.Decimal(5, 4)
  tvaAmount          Decimal?          @db.Decimal(14, 3)
  currency           String            @default("TND") @db.VarChar(10)
  amountPaid         Decimal           @default(0) @db.Decimal(14, 3)
  status             InvoiceStatus     @default(DRAFT)
  invoiceType        InvoiceType       @default(STANDARD)
  dueDate            DateTime?         @db.Timestamptz(6)
  sentAt             DateTime?         @db.Timestamptz(6)
  paidAt             DateTime?         @db.Timestamptz(6)
  pdfUrl             String?           @db.VarChar(500)
  reminderPaused     Boolean           @default(false)
  clientId           String
  client             Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId          String?
  project            Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  proposalId         String?           @unique
  proposal           Proposal?         @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  items              InvoiceItem[]
  payments           Payment[]
  commissions        Commission[]
  reminders          InvoiceReminder[]
  creditNotes        CreditNote[]      @relation("CreditNoteSource")
  appliedCreditNotes CreditNote[]      @relation("CreditNoteApplication")
  documents          Document[]
  deletedAt          DateTime?         @db.Timestamptz(6)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)

  @@unique([projectId, invoiceType])
  @@index([clientId])
  @@index([status])
  @@index([invoiceType])
  @@index([deletedAt])
  @@index([dueDate])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([number])
}

enum CommissionStatus {
  PENDING
  PAID
}

// Manual per-project assignment of which associates get what share of the revenue.
// Set once when the deal is configured (e.g. 70-30 or 50-50 between the 3 partners);
// used to compute Commission rows whenever a payment is recorded against the project.
model ProjectCommissionSplit {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partnerId String
  partner   User     @relation("PartnerCommissionSplits", fields: [partnerId], references: [id], onDelete: Cascade)
  ratePct   Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([projectId, partnerId])
  @@index([projectId])
  @@index([partnerId])
}

// What is owed to an associate for a specific payment received. One Commission row is
// created per (partner, Payment) — a deposit payment and a balance payment on the same
// project each generate their own commission, prorated on the amount actually collected.
model Commission {
  id        String           @id @default(uuid())
  partnerId String
  partner   User             @relation("PartnerCommissions", fields: [partnerId], references: [id], onDelete: Cascade)
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentId String           @unique
  payment   Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  // Amount the commission is computed from (the payment amount actually received) and the
  // resulting share, both in the invoice's currency.
  basis     Decimal          @db.Decimal(14, 3)
  ratePct   Decimal          @db.Decimal(5, 2)
  amount    Decimal          @db.Decimal(14, 3)
  status    CommissionStatus @default(PENDING)
  paidAt    DateTime?        @db.Timestamptz(6)
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)

  @@index([partnerId])
  @@index([projectId])
  @@index([invoiceId])
  @@index([status])
}

// A credit note records money owed back to a client : issued for an overpayment or as a
// correction against an invoice. Issuing one increments Client.creditBalance.
// When applyCredit() is called, appliedAt is set and creditBalance is decremented.
model CreditNote {
  id                 String    @id @default(uuid())
  number             String    @unique @db.VarChar(100)
  amount             Decimal   @db.Decimal(14, 3)
  reason             String    @db.Text
  invoiceId          String
  invoice            Invoice   @relation("CreditNoteSource", fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Application tracking — null means not yet consumed
  appliedAt          DateTime? @db.Timestamptz(6)
  appliedToInvoiceId String?
  appliedToInvoice   Invoice?  @relation("CreditNoteApplication", fields: [appliedToInvoiceId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([clientId])
  @@index([appliedToInvoiceId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  description String   @db.VarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(14, 3)
  total       Decimal  @db.Decimal(14, 3)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

model InvoiceReminder {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(100)
  sentAt    DateTime @default(now()) @db.Timestamptz(6)
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

// Client Success Center
model ClientSuccess {
  id              String                  @id @default(uuid())
  clientId        String                  @unique
  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  score           Int                     @default(0)
  objectives      SuccessObjective[]
  metrics         SuccessMetric[]
  recommendations SuccessRecommendation[]
  timeline        SuccessTimeline[]
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(6)

  @@index([clientId])
}

model SuccessObjective {
  id           String        @id @default(uuid())
  title        String        @db.VarChar(255)
  description  String?       @db.Text
  targetValue  Decimal?      @db.Decimal(12, 2)
  currentValue Decimal?      @db.Decimal(12, 2)
  unit         String?       @db.VarChar(50)
  targetDate   DateTime?     @db.Timestamptz(6)
  completedAt  DateTime?     @db.Timestamptz(6)
  successId    String
  success      ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model SuccessMetric {
  id           String          @id @default(uuid())
  name         String          @db.VarChar(255)
  initialValue Decimal         @db.Decimal(12, 2)
  currentValue Decimal         @db.Decimal(12, 2)
  unit         String?         @db.VarChar(50)
  successId    String
  success      ClientSuccess   @relation(fields: [successId], references: [id], onDelete: Cascade)
  history      MetricHistory[]
  createdAt    DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model MetricHistory {
  id        String        @id @default(uuid())
  value     Decimal       @db.Decimal(12, 2)
  date      DateTime      @default(now()) @db.Timestamptz(6)
  metricId  String
  metric    SuccessMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)

  @@index([metricId])
  @@index([metricId, date])
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model SuccessRecommendation {
  id          String                 @id @default(uuid())
  title       String                 @db.VarChar(255)
  description String?                @db.Text
  priority    RecommendationPriority @default(MEDIUM)
  status      RecommendationStatus   @default(PENDING)
  successId   String
  success     ClientSuccess          @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, priority])
}

model SuccessTimeline {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(255)
  description String?       @db.Text
  eventType   String        @db.VarChar(100)
  date        DateTime      @default(now()) @db.Timestamptz(6)
  successId   String
  success     ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, date])
}

// AI Conversation history : persisted per user
enum AiMessageRole {
  USER
  ASSISTANT
}

model AiConversation {
  id        String      @id @default(uuid())
  title     String      @db.VarChar(255)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  persona   String?     @db.VarChar(100)
  messages  AiMessage[]
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, createdAt])
}

model AiMessage {
  id             String         @id @default(uuid())
  role           AiMessageRole
  content        String         @db.Text
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// Custom question asked by a logged-in user from the FAQ section
model CustomQuestion {
  id        String                  @id @default(uuid())
  subject   String                  @db.VarChar(255)
  status    CustomQuestionStatus    @default(OPEN)
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CustomQuestionMessage[]
  createdAt DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt DateTime                @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// A single message within a custom question conversation thread
model CustomQuestionMessage {
  id         String         @id @default(uuid())
  content    String         @db.Text
  authorRole Role
  authorId   String
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questionId String
  question   CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)

  @@index([questionId])
  @@index([questionId, createdAt])
}

model PermissionProfile {
  id          String              @id @default(uuid())
  name        String              @unique
  description String?
  permissions Json
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  managers    ManagerPermission[]
}

model ManagerPermission {
  id        String             @id @default(uuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String?
  profile   PermissionProfile? @relation(fields: [profileId], references: [id])
  overrides Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model TimeEntry {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description     String?  @db.VarChar(500)
  minutes         Int
  date            DateTime @db.Date
  billed          Boolean  @default(false)
  billedInvoiceId String?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  @@index([projectId])
  @@index([userId])
  @@index([date])
  @@index([projectId, billed])
}

enum SiteContentType {
  TEXT
  RICHTEXT
  IMAGE
  BOOLEAN
  // Serialized JSON array in `value` — one field holds a whole variable-length
  // list (e.g. FAQ questions, problem cards) so the admin edits/reorders/
  // removes items as a unit instead of one SiteContent row per array index.
  JSON
  // A value constrained to a fixed set of choices (e.g. section background:
  // "none" | "surface-warm" | "ink" | "primary-soft"). The allowed options
  // live in the matching client-side select field, not in the database —
  // this type only signals the admin UI to render a <select> instead of a
  // free-text input.
  SELECT
}

enum SiteContentSection {
  HERO
  SERVICES
  ABOUT
  TESTIMONIALS
  CONTACT
  SEO
  PROBLEMS
  HOW_IT_WORKS
  DIFFERENTIATORS
  BUSINESS_IMPACT
  FAQ
  SOLUTIONS
  CASE_STUDIES
  FINAL_CTA
  SOCIAL_PROOF
}

model SiteContent {
  id        String             @id @default(uuid())
  key       String             @db.VarChar(120)
  locale    String             @db.VarChar(5) // "fr" | "en"
  value     String             @db.Text
  type      SiteContentType    @default(TEXT)
  section   SiteContentSection
  label     String             @db.VarChar(120)
  updatedAt DateTime           @updatedAt

  @@unique([key, locale])
  @@index([locale, section])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?  @db.VarChar(50)
  action     String   @db.VarChar(100)
  entityType String   @db.VarChar(100)
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
