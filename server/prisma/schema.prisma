generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role definitions
enum Role {
  ADMIN
  MANAGER
  CLIENT
  FREELANCER
}

// Status of a custom question asked from the FAQ
enum CustomQuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

// Project status options
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

// Task status options
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

// Lead status options for sales pipeline
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

// Contact request status options
enum ContactStatus {
  NEW
  READ
  ARCHIVED
}

// Freelancer Application status
enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// Client Onboarding Step Status
enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// Contract Status
enum ContractStatus {
  PENDING
  SIGNED
}

// Payment Status
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// Specification Approval Status
enum SpecApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Service request status options
enum ServiceRequestStatus {
  NEW
  IN_REVIEW
  IN_PROGRESS
  WAITING_CLIENT
  COMPLETED
  CANCELLED
}

enum ServiceRequestType {
  SUPPORT
  NEW_PROJECT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Single-tenant Company model (one record for Secritou)
model Company {
  id          String   @id @default(uuid())
  singleton   Boolean  @default(true)
  name        String   @db.VarChar(255)
  website     String?  @db.VarChar(255)
  logoUrl     String?  @db.VarChar(255)
  primaryColor String? @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@unique([singleton])
}

// User model for all platform users
model User {
  id                  String               @id @default(uuid())
  email               String               @db.VarChar(255)
  name                String               @db.VarChar(255)
  passwordHash        String               @db.VarChar(255)
  role                Role                 @default(CLIENT)
  mustChangePassword  Boolean              @default(false)
  clientId            String?
  client              Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId           String?
  service             Service?             @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks               Task[]               @relation("AssignedTasks")
  comments            Comment[]
  refreshTokens       RefreshToken[]
  freelancerProfile FreelancerProfile?
  notifications Notification[]
  resetToken String? @db.VarChar(255)
  resetTokenExpiry DateTime? @db.Timestamptz(6)
  freelancerApplications FreelancerApplication[]
  clientOnboardingsAsAssignee ClientOnboarding[] @relation("ClientOnboardingAssignedUser")
  proposalHistories    ProposalHistory[]
  approvalTimelines    ApprovalTimeline[]
  documentAccessLogs   DocumentAccessLog[]
  assignedServiceRequests ServiceRequestComment[] @relation("ServiceRequestCommentAuthor")
  serviceRequestHistory   ServiceRequestHistory[] @relation("ServiceRequestHistoryUser")
  serviceRequestAssignments ServiceRequest[]      @relation("ServiceRequestAssignee")
  recordedPayments Payment[]  @relation("RecordedPayments")
  aiConversations     AiConversation[]
  customQuestions        CustomQuestion[]
  customQuestionMessages CustomQuestionMessage[]
  managerPermission   ManagerPermission?
  uploadedDocuments        Document[]    @relation("UploadedDocuments")
  signedDocuments          Document[]    @relation("SignedDocuments")
  projectClientApprovals   Project[]     @relation("ProjectClientApprovals")
  assignedLeads            Lead[]        @relation("ManagerLeads")
  givenRatings             Rating[]      @relation("RatedByUser")
  createdAt           DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(6)

  @@unique([email])

  // Indexes for faster queries
  @@index([clientId])
  @@index([email])
  @@index([resetToken])
  @@index([serviceId])
}

// Service (business pole/department) : e.g. "Technology Solutions", "AI & Automation".
// Leads, clients and users are attached to a service so MANAGERs can be scoped to their pole.
model Service {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100) @unique
  leads     Lead[]
  projects  Project[]
  users     User[]
  clients   Client[]
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

// Lead model for potential clients/sales pipeline
model Lead {
  id                String     @id @default(uuid())
  name              String     @db.VarChar(255)
  email             String?    @db.VarChar(255)
  phone             String?    @db.VarChar(50)
  source            String?    @db.VarChar(100)
  status            LeadStatus @default(NEW)
  notes             String?    @db.Text
  serviceId         String?
  service           Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  convertedClientId String?
  convertedClient   Client?    @relation("ConvertedLead", fields: [convertedClientId], references: [id], onDelete: SetNull)
  archivedAt        DateTime?  @db.Timestamptz(6)
  sourceContactId   String?    @unique
  sourceContact     ContactRequest? @relation(fields: [sourceContactId], references: [id])
  assignedManagerId String?
  assignedManager   User?      @relation("ManagerLeads", fields: [assignedManagerId], references: [id])
  department        String?    @db.VarChar(255)
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email])
  @@index([archivedAt])
}

// Client model for paying/active clients
model Client {
  id               String           @id @default(uuid())
  name             String           @db.VarChar(255)
  email            String?          @db.VarChar(255)
  phone            String?          @db.VarChar(50)
  projects         Project[]
  users            User[]
  serviceRequests  ServiceRequest[]
  documents        Document[]
  proposals        Proposal[]
  approvals        Approval[]
  invoices         Invoice[]
  creditNotes      CreditNote[]
  creditBalance    Decimal          @default(0) @db.Decimal(12, 2)
  clientSuccess    ClientSuccess?
  clientOnboardings ClientOnboarding[]
  serviceId        String?
  service          Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  convertedLeads   Lead[]           @relation("ConvertedLead")
  archivedAt       DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([email])
  @@index([archivedAt])
  @@index([createdAt])
}
model ServiceRequest {
  id           String               @id @default(uuid())
  title        String               @db.VarChar(255)
  description  String?              @db.Text
  type         ServiceRequestType   @default(NEW_PROJECT)
  status       ServiceRequestStatus @default(NEW)
  priority     Priority             @default(NORMAL)
  assignedToId String?
  assignedTo   User?                @relation("ServiceRequestAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  clientId     String
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(6)

  comments  ServiceRequestComment[]
  history   ServiceRequestHistory[]
  proposal  Proposal?

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([assignedToId])
}

model ServiceRequestComment {
  id               String         @id @default(uuid())
  body             String         @db.Text
  isInternal       Boolean        @default(false)
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?          @relation("ServiceRequestCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, isInternal])
}

model ServiceRequestHistory {
  id               String         @id @default(uuid())
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?          @relation("ServiceRequestHistoryUser", fields: [userId], references: [id], onDelete: SetNull)
  field            String         @db.VarChar(100)
  oldValue         String?        @db.VarChar(500)
  newValue         String?        @db.VarChar(500)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)

  @@index([serviceRequestId])
  @@index([serviceRequestId, createdAt])
}
model Project {
  id                String                @id @default(uuid())
  name              String                @db.VarChar(255)
  description       String?               @db.Text
  status            ProjectStatus         @default(PLANNING)
  clientId          String?
  client            Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId         String?
  service           Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  tasks             Task[]
  documents         Document[]
  proposals         Proposal[]            @relation("ProjectProposals")
  proposalId        String?               @unique
  proposal          Proposal?             @relation("ProjectProposal", fields: [proposalId], references: [id])
  approvals         Approval[]
  invoices          Invoice[]
  clientOnboardings ClientOnboarding[]
  // Snapshot from the accepted proposal (budget is free-text like Project elsewhere; deadline
  // mirrors the proposal's expiry). Filled by the acceptance cascade, editable afterwards.
  budget            String?               @db.VarChar(255)
  deadline          DateTime?             @db.Timestamptz(6)
  // Client brief questionnaire
  serviceType       String?               @db.VarChar(50)
  briefData         Json?
  briefCompleted    Boolean               @default(false)
  briefCompletedAt  DateTime?             @db.Timestamptz(6)
  // Client final approval (triggers COMPLETED + balance invoice)
  clientApprovedAt      DateTime?         @db.Timestamptz(6)
  clientApprovedById    String?
  clientApprovedBy      User?             @relation("ProjectClientApprovals", fields: [clientApprovedById], references: [id], onDelete: SetNull)
  archivedAt        DateTime?             @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([status, updatedAt])
  @@index([createdAt])
  @@index([clientId])
  @@index([archivedAt])
  @@index([serviceId])
}
model Task {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(255)
  description String?     @db.Text
  status      TaskStatus  @default(TODO)
  dueDate     DateTime?   @db.Timestamptz(6)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Comment[]
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([projectId, assigneeId])
  @@index([assigneeId])
  @@index([dueDate, status])
}
model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([taskId])
  @@index([authorId])
}

// ContactRequest model for contact form submissions
model ContactRequest {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(255)
  email          String        @db.VarChar(255)
  phone          String?       @db.VarChar(50)
  serviceType    String        @db.VarChar(255)
  budget         String?       @db.VarChar(255)
  company        String        @db.VarChar(255)
  message        String        @db.Text
  status         ContactStatus @default(NEW)
  convertedLead  Lead?
  convertedAt    DateTime?     @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}
model Skill {
  id           String               @id @default(uuid())
  name         String               @unique @db.VarChar(100)
  freelancers  FreelancerProfile[]
}

// FreelancerProfile model for freelancer details
model FreelancerProfile {
  id          String               @id @default(uuid())
  userId      String               @unique
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?              @db.Text
  hourlyRate  Decimal?             @db.Decimal(10, 2)
  availability Boolean             @default(true)
  rating      Decimal?             @db.Decimal(2, 1) // Average rating (1-5)
  reviewCount Int                  @default(0)
  skills      Skill[]
  portfolio   PortfolioItem[]
  ratings     Rating[]
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @db.Timestamptz(6)

  // Indexes for faster queries
  @@index([userId])
  @@index([userId, createdAt])
}

model PortfolioItem {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?        @db.Text
  url         String?        @db.VarChar(255)
  imageUrl    String?        @db.VarChar(255)
  freelancerId String
  freelancer  FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  @@index([freelancerId])
}

model Rating {
  id              String            @id @default(uuid())
  score           Int
  comment         String?           @db.Text
  freelancerId    String
  freelancer      FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  ratedByUserId   String?
  ratedByUser     User?             @relation("RatedByUser", fields: [ratedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)

  @@index([freelancerId])
}

enum NotificationType {
  PROPOSAL_SENT
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  PROPOSAL_EXPIRED
  APPROVAL_REQUESTED
  APPROVAL_ACCEPTED
  APPROVAL_REJECTED
  INVOICE_SENT
  INVOICE_OVERDUE
  PAYMENT_RECEIVED
  PROJECT_STATUS_CHANGED
  TASK_ASSIGNED
  SERVICE_REQUEST_CREATED
  SERVICE_REQUEST_STATUS_CHANGED
  SERVICE_REQUEST_COMMENT
  BRIEF_COMPLETED
  DOCUMENT_SIGNED
  LEAD_CONVERTED
  FREELANCER_APPLICATION
  GENERAL
}

// Notification model for user notifications
model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String             @db.VarChar(255)
  message   String             @db.Text
  type      NotificationType   @default(GENERAL)
  entityId  String?            @db.VarChar(255)
  link      String?            @db.VarChar(500)
  read      Boolean            @default(false)
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt])
}
model Document {
  id               String               @id @default(uuid())
  name             String               @db.VarChar(255)
  title            String               @db.VarChar(255)
  description      String?              @db.Text
  type             DocumentType         @default(OTHER)
  url              String               @db.VarChar(500)
  fileUrl          String?              @db.VarChar(500)
  fileKey          String?              @db.VarChar(500)
  version          Int                  @default(1)
  parentId         String?
  parent           Document?            @relation("DocumentVersioning", fields: [parentId], references: [id], onDelete: SetNull)
  children         Document[]           @relation("DocumentVersioning")
  tags             String[]
  accessLevel      DocumentAccessLevel  @default(CLIENT_ADMIN)
  clientId         String?
  client           Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedById     String?
  uploadedBy       User?                @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  signedAt         DateTime?            @db.Timestamptz(6)
  signedByClientId String?
  signedByClient   User?                @relation("SignedDocuments", fields: [signedByClientId], references: [id], onDelete: SetNull)
  accessLog        DocumentAccessLog[]
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([projectId])
  @@index([type])
  @@index([tags])
  @@index([createdAt])
}
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @db.VarChar(64)
  familyId  String    @db.VarChar(36)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// Freelancer Application model for join us requests
model FreelancerApplication {
  id              String            @id @default(uuid())
  firstName       String            @db.VarChar(255)
  lastName        String            @db.VarChar(255)
  email           String            @db.VarChar(255)
  phone           String?           @db.VarChar(50)
  position        String            @db.VarChar(255)
  cvUrl           String            @db.VarChar(500)
  cvKey           String?           @db.VarChar(500)
  portfolioUrl    String            @db.VarChar(500)
  portfolioKey    String?           @db.VarChar(500)
  status          ApplicationStatus @default(PENDING)
  rejectionReason String?           @db.Text
  userId          String?
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountCreatedAt DateTime?
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6)

  @@unique([email])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

// Client Onboarding model
model ClientOnboarding {
  id            String           @id @default(uuid())
  projectId     String           @unique
  // Restrict (not Cascade): deleting a project must not silently destroy its onboarding
  // record. deleteProject blocks while an onboarding exists; archive the project instead.
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  clientId      String
  client        Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedUserId String?
  assignedUser  User?            @relation("ClientOnboardingAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  steps         OnboardingStep[]
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)

  @@index([projectId])
  @@index([clientId])
}

// Onboarding Step model
model OnboardingStep {
  id               String               @id @default(uuid())
  onboardingId     String
  onboarding       ClientOnboarding     @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  stepType         String               @db.VarChar(100)
  title            String               @db.VarChar(255)
  description      String?              @db.Text
  status           OnboardingStepStatus @default(PENDING)
  orderIndex       Int                  @default(0)
  deadline         DateTime?            @db.Timestamptz(6)
  completedAt      DateTime?            @db.Timestamptz(6)
  contract         Contract?
  payment          Payment?
  questionnaire    Questionnaire?
  specifications   Specifications?
  kickoff          KickoffMeeting?
  production       ProductionProgress?
  delivery         Delivery?
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)

  @@index([onboardingId])
  @@index([onboardingId, orderIndex])
}

// Contract model
model Contract {
  id               String           @id @default(uuid())
  onboardingStepId String           @unique
  onboardingStep   OnboardingStep   @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  contractUrl      String?          @db.VarChar(500)
  status           ContractStatus   @default(PENDING)
  signedAt         DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
}

// Payment model
model Payment {
  id               String           @id @default(uuid())
  onboardingStepId String?          @unique
  onboardingStep   OnboardingStep?  @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  invoiceId        String?
  invoice          Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount           Decimal?         @db.Decimal(10, 2)
  amountPaid       Decimal?         @db.Decimal(10, 2)
  method           String?          @db.VarChar(100)
  reference        String?          @db.VarChar(255)
  recordedById     String?
  recordedBy       User?            @relation("RecordedPayments", fields: [recordedById], references: [id], onDelete: SetNull)
  status           PaymentStatus    @default(UNPAID)
  deadline         DateTime?        @db.Timestamptz(6)
  paidAt           DateTime?        @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([recordedById])
}

// Questionnaire model
model Questionnaire {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  serviceType      String       @db.VarChar(100)
  data             Json?
  isDraft          Boolean      @default(true)
  submittedAt      DateTime?    @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Specifications model
model Specifications {
  id               String               @id @default(uuid())
  onboardingStepId String               @unique
  onboardingStep   OnboardingStep       @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  requirements     String?              @db.Text
  objectives       String?              @db.Text
  features         String?              @db.Text
  deliverables     String?              @db.Text
  timeline         String?              @db.Text
  approvalStatus   SpecApprovalStatus   @default(PENDING)
  feedback         String?              @db.Text
  approvedAt       DateTime?            @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)
}

// Kickoff Meeting model
model KickoffMeeting {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  meetingDate      DateTime?    @db.Timestamptz(6)
  participants     String?      @db.Text
  meetingLink      String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Production Progress model
model ProductionProgress {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  analysis         Int          @default(0)
  design           Int          @default(0)
  development      Int          @default(0)
  testing          Int          @default(0)
  deployment       Int          @default(0)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Delivery model
model Delivery {
  id               String       @id @default(uuid())
  onboardingStepId String       @unique
  onboardingStep   OnboardingStep @relation(fields: [onboardingStepId], references: [id], onDelete: Cascade)
  deliverables     String?      @db.Text
  documentation    String?      @db.VarChar(500)
  accessDetails    String?      @db.Text
  userGuides       String?      @db.VarChar(500)
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
}

// Proposal Center
enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

model Proposal {
  id               String         @id @default(uuid())
  title            String         @db.VarChar(255)
  description      String?        @db.Text
  status           ProposalStatus @default(DRAFT)
  version          Int            @default(1)
  amount           Decimal?       @db.Decimal(12, 2)
  currency         String         @default("TND") @db.VarChar(10)
  expiresAt        DateTime?      @db.Timestamptz(6)
  viewedAt         DateTime?      @db.Timestamptz(6)
  acceptedAt       DateTime?      @db.Timestamptz(6)
  rejectedAt       DateTime?      @db.Timestamptz(6)
  pdfUrl           String?        @db.VarChar(500)
  // Denormalized snapshot of the recipient, captured at creation. When a proposal is created
  // from a Lead these are pre-filled from the lead so the proposal carries the lead's contact
  // details independently of the (always-present) Client record.
  clientName       String?        @db.VarChar(255)
  email            String?        @db.VarChar(255)
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?       @relation("ProjectProposals", fields: [projectId], references: [id], onDelete: SetNull)
  serviceRequestId String?         @unique
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  sections         ProposalSection[]
  history          ProposalHistory[]
  invoice          Invoice?
  linkedProject    Project?         @relation("ProjectProposal")
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([serviceRequestId])
}

model ProposalSection {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(255)
  content     String?  @db.Text
  orderIndex  Int      @default(0)
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([proposalId])
  @@index([proposalId, orderIndex])
}

model ProposalHistory {
  id          String   @id @default(uuid())
  action      String   @db.VarChar(100)
  comment     String?  @db.Text
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([proposalId])
  @@index([proposalId, createdAt])
}

// Approval Center
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  COMMENTED
}

model Approval {
  id          String         @id @default(uuid())
  title       String         @db.VarChar(255)
  description String?        @db.Text
  status      ApprovalStatus @default(PENDING)
  dueDate     DateTime?      @db.Timestamptz(6)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachments ApprovalAttachment[]
  timeline    ApprovalTimeline[]
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model ApprovalAttachment {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  url         String   @db.VarChar(500)
  approvalId  String
  approval    Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([approvalId])
}

model ApprovalTimeline {
  id          String         @id @default(uuid())
  action      String         @db.VarChar(100)
  comment     String?        @db.Text
  status      ApprovalStatus
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  approvalId  String
  approval    Approval       @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)

  @@index([approvalId])
  @@index([approvalId, createdAt])
}

// Document Center
enum DocumentType {
  WELCOME_LETTER
  CONTRACT
  SPECS
  CLIENT_BRIEF
  QUOTE
  INVOICE_DEPOSIT
  INVOICE_BALANCE
  ROADMAP
  DELIVERABLE
  GUIDE
  REPORT
  INVOICE
  OTHER
}

enum DocumentAccessLevel {
  ADMIN_ONLY
  ADMIN_FREELANCER
  CLIENT_ADMIN
  ALL
}

model DocumentAccessLog {
  id          String           @id @default(uuid())
  action      String           @db.VarChar(100)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  documentId  String
  document    Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ipAddress   String?          @db.VarChar(45)
  userAgent   String?          @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)

  @@index([documentId])
  @@index([userId])
  @@index([documentId, createdAt])
}

// Invoice Center
enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Invoice {
  id                String        @id @default(uuid())
  number            String        @db.VarChar(100) @unique
  title             String        @db.VarChar(255)
  description       String?       @db.Text
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("TND") @db.VarChar(10)
  amountPaid        Decimal       @default(0) @db.Decimal(12, 2)
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime?     @db.Timestamptz(6)
  sentAt            DateTime?     @db.Timestamptz(6)
  paidAt            DateTime?     @db.Timestamptz(6)
  pdfUrl            String?       @db.VarChar(500)
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  proposalId        String?       @unique
  proposal          Proposal?     @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  items             InvoiceItem[]
  payments          Payment[]
  reminders         InvoiceReminder[]
  creditNotes       CreditNote[]
  createdAt         DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([number])
}

// A credit note records money owed back to a client : issued for an overpayment or as a
// correction against an invoice. Issuing one increments Client.creditBalance.
model CreditNote {
  id        String   @id @default(uuid())
  number    String   @db.VarChar(100) @unique
  amount    Decimal  @db.Decimal(12, 2)
  reason    String   @db.Text
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([clientId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  description String   @db.VarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

model InvoiceReminder {
  id          String   @id @default(uuid())
  type        String   @db.VarChar(100)
  sentAt      DateTime @default(now()) @db.Timestamptz(6)
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

// Client Success Center
model ClientSuccess {
  id              String             @id @default(uuid())
  clientId        String             @unique
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  score           Int                @default(0)
  objectives      SuccessObjective[]
  metrics         SuccessMetric[]
  recommendations SuccessRecommendation[]
  timeline        SuccessTimeline[]
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(6)

  @@index([clientId])
}

model SuccessObjective {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(255)
  description    String?       @db.Text
  targetValue    Decimal?      @db.Decimal(12, 2)
  currentValue   Decimal?      @db.Decimal(12, 2)
  unit           String?       @db.VarChar(50)
  targetDate     DateTime?     @db.Timestamptz(6)
  completedAt    DateTime?     @db.Timestamptz(6)
  successId      String
  success        ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model SuccessMetric {
  id           String        @id @default(uuid())
  name         String        @db.VarChar(255)
  initialValue Decimal       @db.Decimal(12, 2)
  currentValue Decimal       @db.Decimal(12, 2)
  unit         String?       @db.VarChar(50)
  successId    String
  success      ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  history      MetricHistory[]
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)

  @@index([successId])
}

model MetricHistory {
  id        String        @id @default(uuid())
  value     Decimal       @db.Decimal(12, 2)
  date      DateTime      @default(now()) @db.Timestamptz(6)
  metricId  String
  metric    SuccessMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)

  @@index([metricId])
  @@index([metricId, date])
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model SuccessRecommendation {
  id          String                 @id @default(uuid())
  title       String                 @db.VarChar(255)
  description String?                @db.Text
  priority    RecommendationPriority @default(MEDIUM)
  status      RecommendationStatus   @default(PENDING)
  successId   String
  success     ClientSuccess          @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, priority])
}

model SuccessTimeline {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(255)
  description String?       @db.Text
  eventType   String        @db.VarChar(100)
  date        DateTime      @default(now()) @db.Timestamptz(6)
  successId   String
  success     ClientSuccess @relation(fields: [successId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)

  @@index([successId])
  @@index([successId, date])
}

// AI Conversation history : persisted per user
enum AiMessageRole {
  USER
  ASSISTANT
}

model AiConversation {
  id        String      @id @default(uuid())
  title     String      @db.VarChar(255)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, createdAt])
}

model AiMessage {
  id             String         @id @default(uuid())
  role           AiMessageRole
  content        String         @db.Text
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// Custom question asked by a logged-in user from the FAQ section
model CustomQuestion {
  id        String                  @id @default(uuid())
  subject   String                  @db.VarChar(255)
  status    CustomQuestionStatus    @default(OPEN)
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CustomQuestionMessage[]
  createdAt DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt DateTime                @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// A single message within a custom question conversation thread
model CustomQuestionMessage {
  id         String         @id @default(uuid())
  content    String         @db.Text
  authorRole Role
  authorId   String
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  questionId String
  question   CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)

  @@index([questionId])
  @@index([questionId, createdAt])
}

model PermissionProfile {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  permissions Json
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  managers    ManagerPermission[]
}

model ManagerPermission {
  id        String             @id @default(uuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String?
  profile   PermissionProfile? @relation(fields: [profileId], references: [id])
  overrides Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}
