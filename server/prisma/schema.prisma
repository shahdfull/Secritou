// Notification model for user notifications
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String           @db.VarChar(255)
  message   String           @db.Text
  type      NotificationType @default(GENERAL)
  entityId  String?          @db.VarChar(255)
  link      String?          @db.VarChar(500)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, read, createdAt])
}

model Document {
  id               String              @id @default(uuid())
  name             String              @db.VarChar(255)
  title            String              @db.VarChar(255)
  description      String?             @db.Text
  type             DocumentType        @default(OTHER)
  url              String              @db.VarChar(500)
  fileUrl          String?             @db.VarChar(500)
  fileKey          String?             @db.VarChar(500)
  version          Int                 @default(1)
  parentId         String?
  parent           Document?           @relation("DocumentVersioning", fields: [parentId], references: [id], onDelete: SetNull)
  children         Document[]          @relation("DocumentVersioning")
  tags             String[]
  accessLevel      DocumentAccessLevel @default(CLIENT_ADMIN)
  clientId         String?
  client           Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId        String?
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // SEC-060: attachment on a specific task, distinct from the project-level projectId above.
  taskId           String?
  task             Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Set only for INVOICE_DEPOSIT/INVOICE_BALANCE PDFs (see documentGenerator.service.ts). Lets
  // invoice.service.ts detect "this invoice's PDF has already been generated" and refuse further
  // line-item edits instead of leaving a stale amount on a document already visible to the client.
  invoiceId        String?
  invoice          Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  uploadedById     String?
  uploadedBy       User?               @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: SetNull)
  signedAt         DateTime?           @db.Timestamptz(6)
  signedByClientId String?
  signedByClient   User?               @relation("SignedDocuments", fields: [signedByClientId], references: [id], onDelete: SetNull)
  accessLog        DocumentAccessLog[]
  createdAt        DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @db.Timestamptz(6)

  @@index([clientId])
  @@index([projectId])
  @@index([taskId])
  @@index([invoiceId])
  @@index([type])
  @@index([tags])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @db.VarChar(64)
  familyId  String    @db.VarChar(36)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// Freelancer Application model for join us requests
model FreelancerApplication {
