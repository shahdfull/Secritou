            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status code is 200\", function () {\n    pm.response.to.have.status(200);\n});\n\nconst jsonData = pm.response.json();\nif (jsonData.data && jsonData.data.tokens) {\n    pm.collectionVariables.set(\"accessToken\", jsonData.data.tokens.accessToken);\n    pm.collectionVariables.set(\"refreshToken\", jsonData.data.tokens.refreshToken);\n}\n"]
              }
            }
          ]
        },
