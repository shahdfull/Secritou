{
  "name": "@secritou/server",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "node --test --import tsx test/run-all.test.ts",
    "test:coverage": "c8 --check-coverage --statements 85 --branches 80 --functions 85 --lines 85 node --test --import tsx test/run-all.test.ts",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:format:check": "prisma format --check",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "migrate:payments": "tsx scripts/migrate-payments.ts",
    "migrate:s3-to-minio": "tsx scripts/migrate-s3-to-minio.ts",
    "test:smtp": "tsx scripts/test-smtp.ts",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@aws-sdk/s3-request-presigner": "^3.1071.0",
    "@bull-board/api": "^8.0.0",
    "@bull-board/express": "^8.0.0",
    "@prisma/client": "^6.19.0",
    "@secritou/shared": "*",
    "@sentry/node": "^10.59.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.78.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "file-type": "^22.0.1",
    "googleapis": "^173.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^8.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.17.6",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.32.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
