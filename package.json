{
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace client\" \"npm:dev --workspace server\"",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "typecheck": "npm run typecheck --workspace client && npm run typecheck --workspace server",
    "lint": "npm run lint --workspace client && npm run lint --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace server",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "docx": "^9.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.4"
  }
}
